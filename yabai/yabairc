#! /bin/sh
# Yabai configuration file

# Lanch yabai as sudoer
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# Make yabai window manager aware of sketchybar
yabai -m config external_bar all:32:0

# default layout (can be bsp, stack or float)
yabai -m config layout bsp

# new window spawns to the right if vertical split, or bottom if horizontal split
yabai -m config window_placement second_child

# padding set to 8px
yabai -m config top_padding 5 #7
yabai -m config bottom_padding 0 #7
yabai -m config left_padding 0 #3
yabai -m config right_padding 0 #3
yabai -m config window_gap 2 #3

# -- mouse settings --
yabai -m config focus_follows_mouse autoraise

# center mouse on window with focus
yabai -m config mouse_follows_focus on

# modifier for clicking and dragging with mouse
yabai -m config mouse_modifier alt
# set modifier + left-click drag to move window
yabai -m config mouse_action1 move
# set modifier + right-click drag to resize window
yabai -m config mouse_action2 resize

# when window is dropped in center of another window, swap them (on edges it will split it)
yabai -m mouse_drop_action swap


yabai -m space 1 --label 1
yabai -m space 2 --label 2
yabai -m space 3 --label 3
yabai -m space 4 --label 4
yabai -m space 5 --label 5
yabai -m space 6 --label 6
yabai -m space 7 --label 7
yabai -m space 8 --label 8
yabai -m space 9 --label 9
yabai -m space 10 --label 10


# Apparence et comportement des fenêtres
yabai -m config window_shadow float         # Ombre uniquement sur les fenêtres flottantes
yabai -m config window_opacity on           # Active la transparence
yabai -m config active_window_opacity 1.0   # Fenêtre active totalement opaque
yabai -m config normal_window_opacity 0.90  # Fenêtres inactives légèrement transparentes
yabai -m config split_ratio 0.5             # Divise l'espace en deux parts égales
yabai -m config auto_balance on             # Rééquilibrage automatique des fenêtres

# Applications en mode float
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Preview$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^QuickTime Player$" manage=off
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^Finder$" manage=off

# Applications sur des espaces spécifiques
yabai -m rule --add app="^Discord$" space=6

# Configuration multi-écrans
yabai -m config display_arrangement_order default      # Ordre naturel des écrans
yabai -m config focus_follows_mouse_display autofocus  # Focus automatique entre écrans

# Optimisations
yabai -m config window_topmost off            # Évite les problèmes de focus
yabai -m config window_origin_display focused # Nouvelles fenêtres sur l'écran actif
yabai -m config window_placement second_child # Meilleure prédictibilité du placement
yabai -m config window_zoom_persist on        # Conserve le zoom après déplacement
yabai -m config window_animation_duration 0.0
yabai -m config window_animation_frame_rate 120
yabai -m config window_opacity_duration 0.0