#!/usr/bin/env sh

# ── Scripting Addition ────────────────────────────────────────────────────────
# Reload the scripting addition whenever Dock restarts (required for some features)
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# ── Bar ───────────────────────────────────────────────────────────────────────
yabai -m config external_bar all:34:0

# ── Layout ────────────────────────────────────────────────────────────────────
yabai -m config layout           bsp
yabai -m config window_placement second_child
yabai -m config split_ratio      0.5
# auto_balance off: preserves manual split ratios; use shift+alt-b to rebalance on demand
yabai -m config auto_balance     off

# ── Gaps & Padding ────────────────────────────────────────────────────────────
yabai -m config top_padding    0
yabai -m config bottom_padding 0
yabai -m config left_padding   0
yabai -m config right_padding  0
yabai -m config window_gap     2

# ── Mouse ─────────────────────────────────────────────────────────────────────
# autofocus: window under cursor gets focus without being raised (less disruptive than autoraise)
yabai -m config focus_follows_mouse autofocus
yabai -m config mouse_modifier      alt
yabai -m config mouse_action1       move
yabai -m config mouse_action2       resize
yabai -m config mouse_drop_action   swap

# ── Window Appearance ─────────────────────────────────────────────────────────
yabai -m config window_shadow           float
yabai -m config window_opacity          on
yabai -m config active_window_opacity   1.0
yabai -m config normal_window_opacity   0.95
yabai -m config window_opacity_duration 0.0

# ── Animations ────────────────────────────────────────────────────────────────
yabai -m config window_animation_duration   0.0
yabai -m config window_animation_frame_rate 120
yabai -m config window_origin_display       focused
yabai -m config window_zoom_persist         on

# ── Spaces ────────────────────────────────────────────────────────────────────
for i in $(seq 1 10); do
    yabai -m space "$i" --label "$i"
done

# ── Float Rules ───────────────────────────────────────────────────────────────
yabai -m rule --add app="^System Settings$"  manage=off
yabai -m rule --add app="^Calculator$"       manage=off
yabai -m rule --add app="^Activity Monitor$" manage=off
yabai -m rule --add app="^Finder$"           manage=off
yabai -m rule --add app="^Structured$"       manage=off
yabai -m rule --add app="^Preview$"          manage=off
yabai -m rule --add app="^QuickTime Player$" manage=off

# ── Space Assignment ──────────────────────────────────────────────────────────
yabai -m rule --add app="^Discord$" space=6

# ── Multi-Display ─────────────────────────────────────────────────────────────
yabai -m config display_arrangement_order default

# ── SketchyBar Refresh Signals ────────────────────────────────────────────────
# Claude Desktop (Electron) doesn't emit space_windows_change reliably;
# trigger a full space refresh on any window lifecycle event for that app
yabai -m signal --add event=window_created     app="^Claude$" action="sketchybar --trigger force_space_refresh"
yabai -m signal --add event=window_destroyed   app="^Claude$" action="sketchybar --trigger force_space_refresh"
yabai -m signal --add event=window_moved       app="^Claude$" action="sketchybar --trigger force_space_refresh"
yabai -m signal --add event=window_minimized   app="^Claude$" action="sketchybar --trigger force_space_refresh"
yabai -m signal --add event=window_deminimized app="^Claude$" action="sketchybar --trigger force_space_refresh"
